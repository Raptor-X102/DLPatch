---
Language: Cpp
BasedOnStyle: LLVM

IndentWidth: 4
UseTab: Never
ColumnLimit: 89
MaxEmptyLinesToKeep: 1

# Все фигурные скобки на той же строке
BreakBeforeBraces: Attach

# Модификаторы доступа БЕЗ отступа
AccessModifierOffset: -4

# Пробелы
SpaceAfterCStyleCast: false
SpaceAfterLogicalNot: false
SpaceBeforeParens: ControlStatements
SpacesInSquareBrackets: false

# Разрешить короткие inline-функции в классах
AllowShortFunctionsOnASingleLine: Inline

# Включения
IncludeBlocks: Preserve
SortIncludes: false

# Прочее
KeepEmptyLinesAtTheStartOfBlocks: false
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false

# Настройки для переноса длинных строк
BinPackArguments: false
BinPackParameters: false
AllowAllArgumentsOnNextLine: false
AllowAllParametersOfDeclarationOnNextLine: false

# Перенос бинарных операторов
BreakBeforeBinaryOperators: NonAssignment

# Перенос длинных выражений
BreakStringLiterals: false

# Настройки для конструкторов
BreakConstructorInitializers: BeforeComma

# Настройки для функций
IndentWrappedFunctionNames: false
SpaceBeforeCtorInitializerColon: true

# Настройки для пространств имен
NamespaceIndentation: All

# Пробелы в угловых скобках шаблонов
SpacesInAngles: false
SpaceAfterTemplateKeyword: false

# Отступы для продолжения строк
ContinuationIndentWidth: 4

# Настройки для switch/case
IndentCaseLabels: false

# Препроцессор
IndentPPDirectives: None

# Комментарии
ReflowComments: true
SpacesBeforeTrailingComments: 1

# Сортировка
SortUsingDeclarations: true
